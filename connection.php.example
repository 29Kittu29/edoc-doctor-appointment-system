<?php
// Sample connection file for Doctor Appointment System
// Rename this file to connection.php and update with your own credentials

$servername = "localhost";   // usually 'localhost' for XAMPP
$username   = "root";        // default MySQL user
$password   = "your_password_here"; // leave empty if no password set
$dbname     = "edoc";        // must match your database name

$database = new mysqli($servername, $username, $password, $dbname);

if ($database->connect_error) {
    die("Connection failed: " . $database->connect_error);
}
?>
